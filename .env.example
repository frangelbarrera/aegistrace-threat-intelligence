# AegisTrace environment variables.
# Copy this file to `.env` and fill in your real API keys.
# All keys are OPTIONAL - AegisTrace runs without any of them.

# AlienVault OTX - https://otx.alienvault.com/api-keys
OTX_API_KEY=

# AbuseIPDB - https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# VirusTotal - https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Pulsedive - https://pulsedive.com/api
PULSEDIVE_API_KEY=

# Optional: override the SQLite database file location
# AEGISTRACE_DB_FILE=threatintel.db

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# AEGISTRACE_LOG_LEVEL=INFO

# Optional: write logs to a rotating file
# AEGISTRACE_LOG_FILE=aegistrace.log
